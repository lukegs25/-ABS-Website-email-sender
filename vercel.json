{
  "version": 2,
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm ci",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "scai-abs-email.vercel.app" }],
      "destination": "https://aiinbusinesssociety.org/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/story",
      "schedule": "0 15 * * *"
    }
  ]
}
